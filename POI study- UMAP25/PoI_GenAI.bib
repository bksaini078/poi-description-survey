@misc{a-orainat_impact_2025,
	location = {Rochester, {NY}},
	title = {The Impact of Artificial Intelligence on Tourism Management Decisions: From Demand Forecasting to Service Customization},
	url = {https://papers.ssrn.com/abstract=5337532},
	doi = {10.2139/ssrn.5337532},
	shorttitle = {The Impact of Artificial Intelligence on Tourism Management Decisions},
	abstract = {This research investigates the impact of artificial intelligence ({AI}) on decision-making processes in tourism organizations, with a particular focus on demand forecasting and service personalization. It explores the application of machine learning, predictive analytics, and intelligent decision-support systems across various tourism firms, including hotels, travel agencies, and destination management organizations. Data was collected through case studies, secondary tourism industry reports, and interviews with sector experts. The findings reveal that {AI} significantly improves predictions of seasonal demand fluctuations, optimization of staffing levels and inventory, and the implementation of dynamic pricing strategies. {AI}-powered tools also enable enhanced customer profiling, allowing for personalized travel packages, tailored recommendations, and real-time service adjustments-ultimately boosting customer satisfaction and loyalty. The study highlights several challenges to {AI} adoption in the Arab tourism sector, such as limited digital infrastructure, high implementation costs, and workforce skill gaps. Despite these barriers, organizations that successfully integrate {AI} gain competitive advantages in operational efficiency, customer retention, and service innovation. Additionally, the research addresses critical issues of data privacy, ethical {AI} deployment, and the need for stakeholder collaboration to ensure sustainable {AI} integration. A conceptual framework is proposed to guide {AI} implementation, balancing technological potential with feasibility and sensitivity to the cultural context of Arab tourism.},
	number = {5337532},
	publisher = {Social Science Research Network},
	author = {A-Orainat, Lamaa},
	urldate = {2026-01-25},
	date = {2025-04-06},
	langid = {english},
	keywords = {Arab tourism sector, artificial intelligence, customer satisfaction, demand forecasting, predictive analytics, service customization, smart tourism, tourism management},
	file = {Full Text PDF:C\:\\Users\\bksai\\Zotero\\storage\\BIJSAYLH\\A-Orainat - 2025 - The Impact of Artificial Intelligence on Tourism Management Decisions From Demand Forecasting to Se.pdf:application/pdf},
}



@inproceedings{hofschen_expected_2023,
	location = {New York, {NY}, {USA}},
	title = {Expected and Experienced Utility of Points of Interest in Tourism Recommender Systems},
	isbn = {978-1-4503-9891-6},
	url = {https://dl.acm.org/doi/10.1145/3563359.3597405},
	doi = {10.1145/3563359.3597405},
	series = {{UMAP} '23 Adjunct},
	abstract = {In this paper we analyze users’ preferences for Points of Interest ({POIs}), before and after the {POIs} are experienced: these are called expected and experienced utilities. State-of-the-art research in other domains, has shown that the difference between the user’s expected utility, which is estimated at the choice stage, and the experienced utility, obtained after the consumption of the item, is domain dependent. This discrepancy is here measured in the tourism domain by focusing on the {POI} recommendation problem. We have designed and implemented an interactive web-based survey to collect the two types of utility data. The analysis of the data collected from a sample of users shows that the two utilities express quite different preferences. This result may be exploited to design novel {POI} recommendation models that can optimally leverage both types of preference signals.},
	pages = {50--55},
	booktitle = {Adjunct Proceedings of the 31st {ACM} Conference on User Modeling, Adaptation and Personalization},
	publisher = {Association for Computing Machinery},
	author = {Hofschen, Katharina and Massimo, David and Ricci, Francesco},
	urldate = {2026-01-24},
	year = {2023},
	date = {2023-06-16},
	file = {Full Text PDF:C\:\\Users\\bksai\\Zotero\\storage\\NZTNSXIS\\Hofschen et al. - 2023 - Expected and Experienced Utility of Points of Interest in Tourism Recommender Systems.pdf:application/pdf},
}

@article{wang_survey_2025,
	title = {A survey on point-of-interest recommendations leveraging heterogeneous data},
	volume = {27},
	issn = {1943-4294},
	url = {https://doi.org/10.1007/s40558-024-00301-3},
	doi = {10.1007/s40558-024-00301-3},
	abstract = {Tourism is an important application domain for recommender systems. In this domain, recommender systems are for example tasked with providing personalized recommendations for transportation, accommodation, points-of-interest ({POIs}), etc. Among these tasks, in particular the problem of recommending {POIs} that are of likely interest to individual tourists has gained growing attention in recent years. Providing {POI} recommendations to tourists can however be especially challenging due to the variability of the user’s context. With the rapid development of the Web and today’s multitude of online services, vast amounts of data from various sources have become available, and these heterogeneous data represent a huge potential to better address the challenges of {POI} recommendation problems. In this work, we provide a survey of published research on the problem of {POI} recommendation between 2021 and 2023. The literature was surveyed to identify the information types, techniques and evaluation methods employed. Based on the analysis, it was observed that the current research tends to focus on a relatively narrow range of information types and there is a significant potential in improving {POI} recommendation by leveraging heterogeneous data. As the first information-centric survey on {POI} recommendation research, this study serves as a reference for researchers aiming to develop increasingly accurate, personalized and context-aware {POI} recommender systems.},
	pages = {29--73},
	number = {1},
	journal = {Information Technology \& Tourism},
	journaltitle = {Information Technology \& Tourism},
	shortjournal = {Inf Technol Tourism},
	author = {Wang, Zehui and Höpken, Wolfram and Jannach, Dietmar},
	urldate = {2026-01-25},
	year = {2025},
	date = {2025-03-01},
	langid = {english},
	keywords = {Heterogeneous data, Point-of-interest recommendation, Recommender systems, Tourism},
	file = {Full Text PDF:C\:\\Users\\bksai\\Zotero\\storage\\ATTJ4KD5\\Wang et al. - 2025 - A survey on point-of-interest recommendations leveraging heterogeneous data.pdf:application/pdf},
}

@misc{qi_rag-optimized_2025,
	title = {{RAG}-Optimized Tibetan Tourism {LLMs}: Enhancing Accuracy and Personalization},
	url = {http://arxiv.org/abs/2408.12003},
	doi = {10.48550/arXiv.2408.12003},
	shorttitle = {{RAG}-Optimized Tibetan Tourism {LLMs}},
	abstract = {With the development of the modern social economy, tourism has become an important way to meet people's spiritual needs, bringing development opportunities to the tourism industry. However, existing large language models ({LLMs}) face challenges in personalized recommendation capabilities and the generation of content that can sometimes produce hallucinations. This study proposes an optimization scheme for Tibet tourism {LLMs} based on retrieval-augmented generation ({RAG}) technology. By constructing a database of tourist viewpoints and processing the data using vectorization techniques, we have significantly improved retrieval accuracy. The application of {RAG} technology effectively addresses the hallucination problem in content generation. The optimized model shows significant improvements in fluency, accuracy, and relevance of content generation. This research demonstrates the potential of {RAG} technology in the standardization of cultural tourism information and data analysis, providing theoretical and technical support for the development of intelligent cultural tourism service systems.},
	number = {{arXiv}:2408.12003},
	publisher = {{arXiv}},
	author = {Qi, Jinhu and Yan, Shuai and Zhang, Yibo and Zhang, Wentao and Jin, Rong and Hu, Yuwei and Wang, Ke},
	urldate = {2026-01-25},
